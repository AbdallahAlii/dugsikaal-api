# .env
########################
# App & Dev toggles
########################
ENV=development
LOG_LEVEL=DEBUG
HOST=0.0.0.0
PORT=9000
DEBUG=1

########################
# Security (REQUIRED)
########################
SECRET_KEY=replace-with-long-random-secret
SECURITY_PASSWORD_SALT=replace-with-salt
ENCRYPTION_KEY=sLXKm6HulAkop3wgsZUbYqABOe8e-YcDGpDz25xwvQM=

########################
# PostgreSQL (REQUIRED)
########################
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=0546655166
DATABASE_NAME=dugsikaal_db

########################
# Redis (REQUIRED)
########################
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

########################
# CORS
########################
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:5174"]
CORS_ALLOW_ORIGIN_REGEX=

########################
# Session / Cookies
########################

SESSION_COOKIE_NAME=session_id
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_MAX_AGE=86400
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=none
CROSS_SITE_COOKIES=false
CROSS_SITE_COOKIES=true
SESSION_COOKIE_SAMESITE=none
SESSION_COOKIE_SECURE=true

SESSION_COOKIE_DOMAIN=
# --------------------------------
# Biometric / Attendance Agent
# --------------------------------

# Base URL of your ERP backend API (where Flask is accessible)
# Dev on same machine:
ERP_API_BASE_URL=http://localhost:2000
# On VPS (example):
# ERP_API_BASE_URL=https://erp.yourdomain.com

# If this agent is dedicated to a single company, set its ID.
# If empty, agent loads devices for all companies.
BIOMETRIC_AGENT_COMPANY_ID=

# How often to sync logs from devices (seconds)
# 900 = 15 min, 3600 = 1 hour
BIOMETRIC_PUNCH_PULL_FREQUENCY=900

# Optional security token – same value must be validated by your backend
# For now in dev you can leave it empty.
BIOMETRIC_AGENT_TOKEN=

# Media
MEDIA_BACKEND=local
MEDIA_MAX_MB=10
MEDIA_ALLOWED_EXTS=["png","jpg","jpeg","webp"]

# If using S3 / MinIO
S3_ENDPOINT_URL=http://127.0.0.1:7000
S3_REGION=us-east-1
S3_BUCKET=erp-media
S3_ACCESS_KEY=your_key
S3_SECRET_KEY=your_secret
S3_PUBLIC_BASE=

# Local
LOCAL_MEDIA_ROOT=media
LOCAL_PUBLIC_BASE=/media




# DigitalPersona 4500 integration
DP4500_MODE=EXE
DP4500_EXE_PATH=C:\dp4500\capture.exe
DP4500_EXE_TIMEOUT=15

#DP4500_MODE=MOCK
#
## MOCK | EXE | DLL
#DP4500_EXE_PATH=C:\dp4500\capture.exe
#DP4500_EXE_TIMEOUT=15

# Optional: if your EXE needs extra args
DP4500_EXE_ARGS=
